# =============================================================================
# Aurelia — Docker Compose (.env ở thư mục gốc repo)
# Copy:  cp .env.example .env
# Chạy:  docker compose up -d --build
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=aurelia
POSTGRES_PASSWORD=aurelia
POSTGRES_DB=aurelia
POSTGRES_PORT=5432

# --- Backend API ---
BACKEND_PORT=8000
JWT_SECRET=change-me-to-a-long-random-string
# Shared secret for MCP → backend service endpoints (X-Service-Key). Empty = dev mode (no check).
INTERNAL_SERVICE_KEY=

# URL frontend công khai (meeting link HR gửi cho ứng viên)
# Local Docker: http://localhost:8080 | Dev hot-reload: http://localhost:3000
FRONTEND_URL=http://localhost:8080
# Production (VPS + nginx): FRONTEND_URL=https://aurelia.io.vn

# Proxy /api từ Next.js → backend (nội bộ host network — không đổi khi có domain)
BACKEND_PROXY_URL=http://127.0.0.1:8000

# --- MinIO (lưu CV PDF, recordings, reports) ---
# Console: http://localhost:9001
MINIO_ROOT_USER=aurelia
MINIO_ROOT_PASSWORD=aurelia-secret
MINIO_ENABLED=true
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=aurelia
MINIO_SECRET_KEY=aurelia-secret

# --- CV extraction — Google Gemini (BẮT BUỘC để parse PDF/DOCX) ---
# Lấy key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model mặc định: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# --- LiveKit (voice interview rooms) ---
# Khởi động: docker compose up -d livekit
# Verify:     ./scripts/verify-livekit.sh
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_PUBLIC_URL=ws://127.0.0.1:7880
# Production: LIVEKIT_PUBLIC_URL=wss://livekit.aurelia.io.vn
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=aurelia_dev_livekit_secret_32chars_min
# STT/TTS for interview worker (optional — defaults to configs/ai-services.yml)
# STT_API_KEY=local
# TTS_API_KEY=local

# --- AI Services (Planning Agent — tùy chọn, backend fallback mock nếu không chạy) ---
AI_SERVICE_URL=http://localhost:8001
# Planning Agent LLM — ưu tiên Gemini; để trống cả hai → skills-based fallback (không LLM).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# OPENAI_API_KEY=   # gateway MaaS/OpenAI-compatible (dùng khi không có GEMINI_API_KEY)