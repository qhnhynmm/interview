# =============================================================================
# Aurelia — AWS EC2 production (.env trên server)
# Copy trên EC2:  cp .env.aws.example .env  && nano .env
# Deploy:         ./scripts/aws/deploy.sh
# =============================================================================

POSTGRES_USER=aurelia
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=aurelia

JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
INTERNAL_SERVICE_KEY=CHANGE_ME_SERVICE_KEY_32CHARS_MIN

# Public URL — thay bằng Elastic IP hoặc domain
# IP only:  http://3.x.x.x
# Domain:   https://aurelia.io.vn
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP
BACKEND_PROXY_URL=http://127.0.0.1:8000

MINIO_ROOT_USER=aurelia
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECRET
MINIO_ENABLED=true
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=aurelia
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

AI_SERVICE_URL=http://127.0.0.1:8001

LIVEKIT_URL=ws://127.0.0.1:7880
# IP only:  ws://YOUR_EC2_PUBLIC_IP:7880
# Domain:    wss://livekit.aurelia.io.vn
LIVEKIT_PUBLIC_URL=ws://YOUR_EC2_PUBLIC_IP:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=aurelia_dev_livekit_secret_32chars_min