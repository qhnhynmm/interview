# AI Services — copy: cp .env.example .env
# Chạy API: cd ai-services && uvicorn app.main:app --reload --port 8001

# OpenAI-compatible LLM (MaaS gateway). Empty → skills-based fallback (no LLM).
OPENAI_API_KEY=

# Backend API (MCP tools delegate here — never read DB directly)
BACKEND_URL=http://localhost:8000