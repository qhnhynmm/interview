# AI Services — copy: cp .env.example .env
# Chạy API: cd ai-services && uvicorn app.main:app --reload --port 8001

APP_ENV=development

# ── Gemini (khuyến nghị) — Planning Agent dùng OpenAI-compatible endpoint của Google
# Lấy key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# ── Hoặc gateway OpenAI-compatible khác (MaaS VNG, OpenAI, …)
# Nếu GEMINI_API_KEY có giá trị thì Gemini được ưu tiên.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_PROVIDER=openai

# Backend API (MCP tools delegate here — never read DB directly)
BACKEND_URL=http://localhost:8000

# ── Interview worker (Gemini Live voice agent — separate process) ──
# BẮT BUỘC: GEMINI_API_KEY ở trên + LiveKit keys bên dưới
# Chạy: cd ai-services && PYTHONPATH=. python -m app.worker dev
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=aurelia_dev_livekit_secret_32chars_min
# Model/giọng: configs/ai-services.yml → interview-agent.live_model / live_voice
# INTERVIEW_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Agent tracing (Arize Phoenix) ──
# UI: http://localhost:6006  |  docker compose up -d phoenix
OTEL_ENABLED=true
OTEL_OTLP_ENDPOINT=http://localhost:6006/v1/traces
# Redact CV/JD/prompts from exported spans (recommended in prod)
OTEL_SENSITIVE=true
# OTEL_CONSOLE=true