# Copy to backend/.env for local development (without Docker).

JWT_SECRET=change-me-to-a-long-random-string

# SQLite (fallback, không cần Docker):
# DATABASE_URL=sqlite:///./data/aurelia.db

# PostgreSQL (mặc định — chạy: docker compose up -d postgres)
DATABASE_URL=postgresql+psycopg://aurelia:aurelia@localhost:5432/aurelia