# =============================================================================
# Aurelia Backend — local dev (không Docker)
# Copy:  cp .env.example .env
# Chạy:  source .venv/bin/activate && uvicorn app.main:app --reload --port 8000
# =============================================================================

APP_ENV=development

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# --- Database ---
# SQLite (không cần Docker):
# DATABASE_URL=sqlite:///./data/aurelia.db

# PostgreSQL (chạy: docker compose up -d postgres)
DATABASE_URL=postgresql+psycopg://aurelia:aurelia@localhost:5432/aurelia

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- MinIO (chạy: docker compose up -d minio) ---
# Console: http://localhost:9001
MINIO_ENABLED=true
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=aurelia
MINIO_SECRET_KEY=aurelia-secret

# --- CV extraction — Google Gemini (BẮT BUỘC để parse PDF/DOCX) ---
# Lấy key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# --- AI Services (Planning Agent — tùy chọn) ---
AI_SERVICE_URL=http://localhost:8001

# --- LiveKit (join tokens) ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=aurelia_dev_livekit_secret_32chars_min
LIVEKIT_PUBLIC_URL=ws://127.0.0.1:7880